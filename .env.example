# Leave unset for local http://localhost development; the client will connect
# directly to ws://<tap-ip>:8081.
#
# Set this for HTTPS deployments. The client converts http(s) to ws(s):
# NEXT_PUBLIC_SHARKBITE_RELAY_ORIGIN=https://relay.example.com
NEXT_PUBLIC_SHARKBITE_RELAY_ORIGIN=

# Local helper/editor overlay. Defaults to enabled in development and disabled in production.
# Set to "true" to force-enable, or "false" to force-disable.
NEXT_PUBLIC_SHARKBITE_ENABLE_HELPER=
